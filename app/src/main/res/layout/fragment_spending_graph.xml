<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/background">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="SPENDING GRAPH" android:textStyle="bold" android:textSize="18sp"
            android:textColor="@color/navy_primary"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="SELECT PERIOD" android:textStyle="bold"
            android:textColor="@color/text_secondary" android:layout_marginTop="16dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="8dp">
            <Button android:id="@+id/btnStart"
                android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                android:text="START" android:backgroundTint="@color/navy_primary"
                android:textColor="@color/white" android:layout_marginEnd="4dp"/>
            <Button android:id="@+id/btnEnd"
                android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                android:text="END" android:backgroundTint="@color/navy_primary"
                android:textColor="@color/white" android:layout_marginStart="4dp"/>
        </LinearLayout>

        <com.github.mikephil.charting.charts.PieChart android:id="@+id/pieChart"
            android:layout_width="match_parent" android:layout_height="280dp"
            android:layout_marginTop="16dp"/>

        <TextView android:id="@+id/tvNoData"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="No spending data for this period" android:gravity="center"
            android:textColor="@color/text_secondary" android:visibility="gone"/>

        <TextView android:id="@+id/tvTotal"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Total: R 0.00" android:textStyle="bold"
            android:textColor="@color/navy_primary" android:layout_marginTop="8dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="CATEGORY TOTALS" android:textStyle="bold"
            android:textColor="@color/navy_primary" android:layout_marginTop="16dp"/>

        <TextView android:id="@+id/tvCatList"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/text_primary" android:layout_marginTop="8dp" android:lineSpacingExtra="4dp"/>
    </LinearLayout>
</ScrollView>